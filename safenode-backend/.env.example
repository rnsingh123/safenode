# ── Server ──────────────────────────────
PORT=5000

# ── CORS — set to your deployed app URL in production ────────
APP_ORIGIN=http://localhost:5173

# ── MongoDB Atlas ────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/safenode

# ── JWT ──────────────────────────────────
# REQUIRED — app will refuse to start without this
JWT_SECRET=replace_with_any_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── Twilio (SMS + Voice Call) ─────────────────────────────────
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio phone number (from Twilio Console → Phone Numbers)
TWILIO_SMS_FROM=+1XXXXXXXXXX

# Set to 'true' to also make a voice call when SOS fires
TWILIO_CALL_ENABLED=true

# WhatsApp sandbox (optional — if you want WhatsApp too)
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Firebase Admin SDK ───────────────────
# Go to Firebase Console → Project Settings → Service Accounts
# → Generate new private key → paste the JSON content below (as one line)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com"}
# OR use a file path instead:
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
